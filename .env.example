# Claw Agents 环境变量
# 复制为 .env 后填写（本地开发）；云服务器请在平台配置同名环境变量

# ── LLM API Key ──────────────────────────────────────────
# 当前激活 provider 的默认 Key（可与下方按 provider 配置二选一）
LLM_API_KEY=

# 按 provider 配置（推荐，支持多 provider 并存）
LLM_API_KEY_GROK=
LLM_API_KEY_DEEPSEEK=
LLM_API_KEY_OPENAI=

# ── QQ Bot App Secret ────────────────────────────────────
# 按 bots[] 数组索引：第 0 个 bot → QQ_APP_SECRET_0
QQ_APP_SECRET_0=
QQ_APP_SECRET_1=

# 或按 agentId（不区分大小写，代码会转大写匹配）
# QQ_APP_SECRET_VIOLET=
# QQ_APP_SECRET_CHRISTINA=

# ── 可选 ─────────────────────────────────────────────────
# 定时任务开关：0 或 false 禁用 cron（节省 token）
# SCHEDULER_ENABLED=0
