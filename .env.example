# Claw Agents 环境变量示例
# 复制为 .env 并在启动前加载，或直接 export 这些变量

# LLM API Key（覆盖 config.json 中的 llm.apiKey）
LLM_API_KEY=your-api-key-here

# 按 provider 覆盖（可选）
# LLM_API_KEY_DEEPSEEK=
# LLM_API_KEY_GROK=

# QQ Bot App Secret（按 bot 索引或 agentId）
# QQ_APP_SECRET_0=
# QQ_APP_SECRET_violet=

# 定时任务开关：0 或 false 禁用 cron（节省 token）
# SCHEDULER_ENABLED=0
